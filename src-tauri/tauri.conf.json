{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local Face Photos",
  "version": "0.1.0",
  "identifier": "com.localfacephotos.desktop",
  "build": {
    "frontendDist": "../desktop"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Local Face Photos",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "externalBin": [
      "binaries/local-face-backend"
    ],
    "resources": []
  }
}
