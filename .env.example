# Local Face Photos configuration examples.
# The app reads these from your shell environment; it does not auto-load this file yet.

# Optional custom Python interpreter for Makefile/run.sh.
PYTHON_BIN=python3

# Optional backend/runtime overrides.
LOCAL_FACE_HOST=127.0.0.1
LOCAL_FACE_PORT=8000
LOCAL_FACE_APP_DATA_DIR=

# InsightFace model and matching thresholds.
INSIGHTFACE_MODEL=buffalo_l
INSIGHTFACE_PROVIDERS=CoreMLExecutionProvider,CPUExecutionProvider
FACE_MATCH_THRESHOLD=0.42
FACE_RECONCILE_THRESHOLD=0.85
FACE_BOX_IOU_THRESHOLD=0.7

# Video scan tuning.
VIDEO_SAMPLE_INTERVAL_SECONDS=3
VIDEO_MAX_FRAMES=300
VIDEO_MIN_DETECTION_SCORE=0.7
VIDEO_MIN_FACE_HEIGHT_RATIO=0.04
VIDEO_CLUSTER_THRESHOLD=0.42
